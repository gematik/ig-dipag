
@startuml
' --- Mermaid-ähnlicher Style ---
skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam roundCorner 10
skinparam defaultFontName "Segoe UI, Trebuchet MS, sans-serif"
skinparam defaultFontSize 13

skinparam activity {
  BorderColor #AAAAAA
  BackgroundColor #ECECFF
  FontColor #333333
  BorderThickness 1.5
  DiamondBorderColor #AAAAAA
  DiamondBackgroundColor #ECECFF
  DiamondFontColor #333333
}

skinparam swimlane {
  BorderColor #BBBBBB
  TitleFontColor #666666
  TitleFontSize 14
}

skinparam partition {
  BorderColor #BBBBBB
  BackgroundColor #F9F9FF
}

skinparam arrow {
  Color #333333
  Thickness 1.5
}
' --- Ende Style ---

|Versicherter|
start
:Registerung des Accounts;
:Zustimmung für den
 Rechnungsemfang erteilen;

|Rechnungsersteller|
:Rechnung erstellen;
:1. Rechnung an DiPagFachdienst übermitteln;

|DiPagFachdienst|
:Berechtigung für den Rechnungsersteller anlegen;

stop

|Versicherter|
start
:Berechtigungen vom Fachdienst abrufen;
if (Berechtigungsstatus ermitteln) is (Status = Berechtigung erteilt) then
  :Berechtigung widerrufen;

else (Status = Berechtigung widerrufen)
  :Berechtigung erteilen;
endif

|DiPagFachdienst|
:Neue Berechtigungskonfiguration speichern;
stop
@enduml

